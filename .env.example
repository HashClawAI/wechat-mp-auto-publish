# Copy to .env and fill in. Do not commit .env.

WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Permanent media_id for cover image (required for draft/add news type).
WECHAT_THUMB_MEDIA_ID=

WECHAT_ARTICLE_TITLE=Hello from automation
WECHAT_ARTICLE_AUTHOR=
WECHAT_ARTICLE_DIGEST=
# HTML body; image src rules per MP docs.
WECHAT_ARTICLE_CONTENT=<p>正文示例</p>
WECHAT_CONTENT_SOURCE_URL=

# 1 = fetch token + print payload only; 0 = call draft/add
DRY_RUN=1
