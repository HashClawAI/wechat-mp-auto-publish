# Copy to .env and fill in. Do not commit .env.

WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Permanent media_id for cover (required for draft/add news).
WECHAT_THUMB_MEDIA_ID=

# --- 图文元数据（与公众平台「草稿」里常见项对应；见 README「草稿 API 能填什么」）---
# 标题：官方建议总长度不超过约 32 个中文字符量级，过长请在后台再改。
WECHAT_ARTICLE_TITLE=Hello from automation
# 作者：≤16 字；不填则接口不传该字段，后台里作者为空。
WECHAT_ARTICLE_AUTHOR=
# 摘要：单图文有效，≤128 字；不填则微信默认抓正文前若干字。
WECHAT_ARTICLE_DIGEST=
# HTML 正文；图片 src 须为 uploadimg 返回的微信 URL。
WECHAT_ARTICLE_CONTENT=<p>正文示例</p>
# 阅读原文链接（可选）。
WECHAT_CONTENT_SOURCE_URL=

# 封面裁剪坐标 X1_Y1_X2_Y2（可选，见官方 draft/add 文档 pic_crop_*）。
# WECHAT_PIC_CROP_235_1=
# WECHAT_PIC_CROP_1_1=

# 评论：1 开启（默认）；0 关闭。仅粉丝可评：1 是；0 否（所有人可评）。
WECHAT_NEED_OPEN_COMMENT=1
WECHAT_ONLY_FANS_CAN_COMMENT=0

# 1 = 只拉 token 并打印将要提交的 JSON；0 = 调用 draft/add 创建草稿
DRY_RUN=1
